# ================================
# 数据库
# ================================
DATABASE_URL="postgresql://goods_user:your_password@postgres:5432/goods_manager"

# ================================
# 授权密钥
# 用于 JWT 签名，请随机生成
# 例如: openssl rand -base64 32
# ================================
JWT_SECRET="your-secret-key-change-this"
INITIAL_ADMIN_EMAIL="admin@example.com"

# ================================
# SMTP 邮件
# 可选，用于邮件通知
# ================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM="PicNote <your@email.com>"
SMTP_SECURE=true

# ================================
# MinIO 对象存储
# 可选；不填则使用本地存储
# 也可在系统设置页面中配置
# ================================
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=goods-manager
# MINIO_USE_SSL=false
# MINIO_PUBLIC_URL=http://localhost:9000

# ================================
# 高德地图
# ================================
# 获取地址: https://console.amap.com/dev/key/app
NEXT_PUBLIC_AMAP_KEY="your_amap_web_js_api_key"
NEXT_PUBLIC_AMAP_SECURITY_CODE="your_amap_security_code"

# 可选：如果 NEXT_PUBLIC_AMAP_KEY 同时开通了 Web Service 能力，可以不填
AMAP_WEB_SERVICE_KEY="your_amap_web_service_key"

# 服务端调用 /api/map-distance 使用的接口鉴权密钥
MAP_DISTANCE_API_KEY="your_map_distance_api_key"

