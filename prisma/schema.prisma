generator client {
  provider      = "prisma-client-js"
  output        = "./generated-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  products    Product[]

  @@unique([name, userId])
  @@index([userId])
}

model Product {
  id              String              @id @default(cuid())
  sku             String?             @unique
  name            String
  costPrice       Float               @default(0)
  stock           Int                 @default(0)
  image           String?
  categoryId      String
  supplierId      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  isPublic        Boolean             @default(true)
  specs           Json?
  pinyin          String?
  isDiscontinued  Boolean             @default(false)
  remark          String?
  userId          String?
  brushKeyword    String?             // 默认刷单搜索关键词
  brushOrderItems     BrushOrderItem[]
  brushOrderPlanItems BrushOrderPlanItem[]
  gallery         GalleryItem[]
  outboundItems   OutboundOrderItem[]
  category        Category            @relation(fields: [categoryId], references: [id])
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  user            User?               @relation(fields: [userId], references: [id])
  orderItems      PurchaseOrderItem[]
  storeOpeningItems StoreOpeningItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([userId, pinyin])
  @@index([userId, createdAt])
}

model Supplier {
  id                 String              @id @default(cuid())
  code               String?
  name               String
  contact            String?
  phone              String?
  email              String?
  address            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userId             String?
  products           Product[]
  purchaseOrderItems PurchaseOrderItem[]
  user               User?               @relation(fields: [userId], references: [id])

  @@unique([code, userId])
  @@index([userId])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  type            String              @default("Purchase")
  status          String              @default("Draft")
  totalAmount     Float               @default(0)
  date            DateTime            @default(now())
  shippingFees    Float               @default(0)
  extraFees       Float               @default(0)
  discountAmount  Float               @default(0)
  paymentVouchers Json?               @default("[]")
  trackingData    Json?               @default("[]")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  note            String?
  shippingAddress String?
  shopName        String?             @default("")
  userId          String?
  user            User?               @relation(fields: [userId], references: [id])
  items           PurchaseOrderItem[]

  @@index([userId, date(sort: Desc)])
  @@index([userId, status])
}

model PurchaseOrderItem {
  id                String        @id @default(cuid())
  purchaseOrderId   String
  productId         String
  supplierId        String?
  quantity          Int
  remainingQuantity Int?
  costPrice         Float
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  product           Product       @relation(fields: [productId], references: [id])
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supplier          Supplier?     @relation(fields: [supplierId], references: [id])
}

model OutboundOrder {
  id        String              @id @default(cuid())
  type      String              @default("Sale")
  date      DateTime            @default(now())
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  status    String              @default("Normal")
  userId    String?
  user      User?               @relation(fields: [userId], references: [id])
  items     OutboundOrderItem[]

  @@index([userId])
}

model OutboundOrderItem {
  id              String        @id @default(cuid())
  outboundOrderId String
  productId       String
  quantity        Int
  price           Float         @default(0)
  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])
}

model GalleryItem {
  id        String   @id @default(cuid())
  url       String
  productId String
  tags      String[] @default([])
  isPublic  Boolean  @default(true)
  type      String   @default("image")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
}

model GallerySubmission {
  id              String   @id @default(cuid())
  urls            Json
  sku             String?
  productName     String?
  status          String   @default("pending")
  notes           String?
  productId       String?
  selectedIndices Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  role               Role                @default(USER)
  status             String              @default("ACTIVE")
  permissions        Json?               @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  shippingAddresses  Json?               @default("[]")
  brushShops         Json?               @default("[]")
  roleProfileId      String?
  brushOrders        BrushOrder[]
  brushOrderPlans    BrushOrderPlan[]
  categories         Category[]
  galleryItems       GalleryItem[]
  gallerySubmissions GallerySubmission[]
  outboundOrders     OutboundOrder[]
  products           Product[]
  purchaseOrders     PurchaseOrder[]
  suppliers          Supplier[]
  systemSettings     SystemSetting[]
  settlements        Settlement[]
  storeOpeningBatches StoreOpeningBatch[]
  roleProfile        RoleProfile?        @relation(fields: [roleProfileId], references: [id])
}

model RoleProfile {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  permissions Json             @default("{}")
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  whitelist   EmailWhitelist[]
  invitations Invitation[]
  users       User[]
}

model EmailWhitelist {
  id            String       @id @default(cuid())
  email         String       @unique
  role          Role         @default(USER)
  permissions   Json?        @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  roleProfileId String?
  roleProfile   RoleProfile? @relation(fields: [roleProfileId], references: [id])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, code])
}

model Invitation {
  id            String       @id @default(cuid())
  token         String       @unique @default(uuid())
  email         String
  role          Role         @default(USER)
  permissions   Json?        @default("{}")
  inviterId     String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  roleProfileId String?
  roleProfile   RoleProfile? @relation(fields: [roleProfileId], references: [id])

  @@index([token])
  @@index([email])
}

model RegistrationRequest {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  reason    String?
  status    String   @default("PENDING")
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model SystemSetting {
  id                     String    @id @default(cuid())
  lowStockThreshold      Int       @default(10)
  allowDataImport        Boolean   @default(true)
  allowGalleryUpload     Boolean   @default(true)
  gallerySortDesc        Boolean   @default(true)
  storageType            String    @default("local")
  minioEndpoint          String?
  minioPort              Int?
  minioAccessKey         String?
  minioSecretKey         String?
  minioBucket            String?
  minioUseSSL            Boolean   @default(true)
  minioPublicUrl         String?
  uploadConflictStrategy String    @default("hash")
  shareExpireDuration    Int       @default(1)
  shareExpireUnit        String    @default("hours")
  backupEnabled          Boolean   @default(false)
  backupIntervalUnit     String    @default("days")
  backupIntervalValue    Int       @default(1)
  backupRetention        Int       @default(10)
  webdavEnabled          Boolean   @default(false)
  webdavUrl              String?
  webdavUser             String?
  webdavPassword         String?
  webdavPath             String?
  lastBackup             DateTime?
  updatedAt              DateTime  @updatedAt
  userId                 String?
  user                   User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BrushOrder {
  id              String           @id @default(cuid())
  date            DateTime         @default(now())
  type            String
  status          String           @default("Draft")
  paymentAmount   Float            @default(0)
  receivedAmount  Float            @default(0)
  commission      Float            @default(0)
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  shopName        String?
  platformOrderId String?
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  items           BrushOrderItem[]

  @@index([userId])
  @@index([userId, platformOrderId])
}

model BrushOrderItem {
  id           String     @id @default(cuid())
  brushOrderId String
  productId    String
  quantity     Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  brushOrder   BrushOrder @relation(fields: [brushOrderId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])
}

model BrushOrderPlan {
  id          String               @id @default(cuid())
  date        DateTime             @default(now())
  title       String?
  shopName    String?
  note        String?
  status      String               @default("Draft")
  userId      String?
  user        User?                @relation(fields: [userId], references: [id])
  items       BrushOrderPlanItem[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([userId, date(sort: Desc)])
}

model BrushOrderPlanItem {
  id            String          @id @default(cuid())
  planId        String
  plan          BrushOrderPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?        @relation(fields: [productId], references: [id])
  productName   String?
  quantity      Int             @default(1)
  searchKeyword String?
  platform      String?
  note          String?
  done          Boolean         @default(false)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([planId])
  @@index([productId])
}

model PageView {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  path      String   @default("/")
  visitorId String   // 匿名访客 ID（来自 cookie）
  ip        String?  // 请求 IP 的 SHA256 hash（隐私保护）
  isUnique  Boolean  @default(false) // 当天该访客首次访问

  @@index([date])
  @@index([visitorId, date])
  @@index([ip, date])
}

model Settlement {
  id                   String           @id @default(cuid())
  date                 DateTime         @default(now())
  totalNet             Float            @default(0)
  serviceFeeRate       Float            @default(0.06)
  serviceFee           Float            @default(0)
  totalAlreadyReceived Float            @default(0)
  finalBalance         Float            @default(0)
  note                 String?
  userId               String?
  user                 User?            @relation(fields: [userId], references: [id])
  items                SettlementItem[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([userId])
  @@index([userId, date(sort: Desc)])
}

model SettlementItem {
  id             String     @id @default(cuid())
  settlementId   String
  platformName   String
  received       Float      @default(0)
  brushing       Float      @default(0)
  receivedToCard Float      @default(0)
  net            Float      @default(0)
  settlement     Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

enum Role {
  USER
  SUPER_ADMIN
}

model StoreOpeningBatch {
  id          String              @id @default(cuid())
  name        String
  date        DateTime            @default(now())
  userId      String?
  user        User?               @relation(fields: [userId], references: [id])
  items       StoreOpeningItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
}

model StoreOpeningItem {
  id            String            @id @default(cuid())
  batchId       String
  batch         StoreOpeningBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  productCode   String?           
  productName   String?           
  productId     String?
  product       Product?          @relation(fields: [productId], references: [id])
  quantity      Int               @default(0)
  unitPrice     Float             @default(0)
  totalAmount   Float             @default(0)
  shippingFee   Float             @default(0)
  
  channel       String?            
  remark        String?           
  checked       Boolean           @default(false)
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([batchId])
  @@index([productId])
}
